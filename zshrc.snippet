
# >>> headroom aliases >>>
export HEADROOM_DB="$HOME/.headroom/memory.db"   # the proxy's real store (not the cwd's ./headroom_memory.db)
alias hr="$HOME/.headroom/venv/bin/headroom"     # base CLI
alias hr-status="hr install status"              # is the proxy up/healthy?
alias hr-mem="hr memory list --db-path \"$HEADROOM_DB\""    # saved memories
alias hr-stats="hr memory stats --db-path \"$HEADROOM_DB\"" # memory summary
alias hr-save="hr output-savings"               # tokens saved
alias mem-save="bash $HOME/.claude/hooks/mem-save.sh"  # save a memory by hand
alias co-dash="python3 $HOME/.carryover/carryover-dash.py"  # local dashboard: memories + wikis
alias hr-dash="open http://127.0.0.1:8787/dashboard"       # headroom's savings dashboard
alias co-wiki-enable="bash $HOME/.carryover/install-wiki.sh" # enable the auto-wiki in the current repo
alias co-wiki-gen="bash $HOME/.carryover/wiki-gen.sh"       # generate/update the current repo's wiki now
alias wiki-enable="bash $HOME/.carryover/install-wiki.sh"   # compat alias of co-wiki-enable
alias wiki-gen="bash $HOME/.carryover/wiki-gen.sh"          # compat alias of co-wiki-gen
co-wiki-prune() {   # drop dead entries (gone worktrees) from carryover's wiki registry
  local reg="$HOME/.carryover/wikis.list"
  [ -f "$reg" ] || { echo "wiki-prune: no wikis registered"; return 0; }
  local before; before=$(grep -c . "$reg" 2>/dev/null || echo 0)
  local tmp="$reg.tmp"; : > "$tmp"
  local d; while IFS= read -r d; do [ -n "$d" ] && [ -d "$d/wiki" ] && printf '%s\n' "$d" >> "$tmp"; done < "$reg"
  mv "$tmp" "$reg"
  local after; after=$(grep -c . "$reg" 2>/dev/null || echo 0)
  echo "wiki-prune: removed $((before - after)) dead, $after remain"
}
alias wiki-prune="co-wiki-prune"                            # compat alias of co-wiki-prune
alias co-recall="bash $HOME/.carryover/recall.sh"          # recall knowledge by keyword
alias co-forget="bash $HOME/.carryover/forget.sh"          # forget memories by keyword (with confirm)
alias hr-recall="bash $HOME/.carryover/recall.sh"          # compat alias of co-recall
alias hr-forget="bash $HOME/.carryover/forget.sh"          # compat alias of co-forget
alias hr-prune="hr memory prune"                           # prune memories (e.g. --older-than 30d --dry-run)
alias hr-on="hr install start"                  # start proxy
alias hr-off="hr install stop"                  # stop proxy

# carryover: enable/disable routing through headroom (global + current session)
carryover() {
  local p="http://127.0.0.1:${HEADROOM_PORT:-8787}"
  # colors + 💼 only on a real terminal (and unless NO_COLOR); empty otherwise → clean pipes/logs
  local R O G Y E D tag="carryover"
  if [ -t 1 ] && [ -z "$NO_COLOR" ]; then
    R=$'\e[0m'; O=$'\e[1;38;5;173m'; G=$'\e[32m'; Y=$'\e[33m'; E=$'\e[31m'; D=$'\e[2m'
    tag="${O}💼 carryover${R}"
  fi
  case "$1" in
    on)
      [ -x "$HOME/.headroom/venv/bin/headroom" ] || { echo "$tag ${Y}routing unavailable${R}${D} — headroom proxy not installed (memory & wiki work without it)${R}"; return 0; }
      [ "$2" = "--session" ] || bash "$HOME/.claude/hooks/carryover-toggle.sh" on
      export ANTHROPIC_BASE_URL="$p" OPENAI_BASE_URL="$p/v1"
      echo "$tag ${G}ON${R}${D} · this shell${2:+ (session only)}${R}";;
    off)
      [ -x "$HOME/.headroom/venv/bin/headroom" ] || { echo "$tag ${D}routing not installed — nothing to turn off${R}"; return 0; }
      [ "$2" = "--session" ] || bash "$HOME/.claude/hooks/carryover-toggle.sh" off
      unset ANTHROPIC_BASE_URL OPENAI_BASE_URL
      echo "$tag ${Y}OFF${R}${D} · this shell${2:+ (session only)}${R}"
      [ -s "$HOME/.carryover/wrapped" ] && echo "  ${Y}⚠${R}${D} still routing (off only affects Claude): $(tr '\n' ' ' < "$HOME/.carryover/wrapped")— revert each tool's config, or 'carryover wrap --clear' to dismiss${R}";;
    status) bash "$HOME/.claude/hooks/carryover-toggle.sh" status;;
    "")
      bash "$HOME/.claude/hooks/carryover-toggle.sh" status
      local -a cmds=(
        "carryover on/off:enable/disable routing · activar/desactivar el routing"
        "carryover status:show this status · mostrar este estado"
        "carryover doctor:health-check (--fix to repair) · chequeo (--fix para arreglar)"
        "carryover persist:make the proxy survive reboot · que el proxy sobreviva al reboot"
        "carryover update:pull latest + re-sync this machine · traer cambios y re-sincronizar"
        "carryover version:installed version + pending updates · versión instalada y updates"
        "carryover wrap <t>:route another tool (Cursor, Codex…) · enrutar otra herramienta"
        "carryover uninstall:remove carryover, keep headroom · quitar carryover, deja headroom"
        "co-wiki-enable:enable the auto-wiki in this repo · activar la auto-wiki en este repo"
        "co-wiki-gen:regenerate the repo wiki · regenerar la wiki del repo"
        "co-wiki-prune:drop dead entries from the wiki registry · podar wikis muertas del registro"
        "co-dash:open the local dashboard · abrir el panel local"
        "co-recall <q>:recall knowledge by keyword · recordar conocimiento por keyword"
        "co-forget <q>:delete memories by keyword (confirm) · borrar memorias por keyword"
        "hr-prune:prune old memories, e.g. --older-than 30d · purgar memorias viejas"
        "hr-*:headroom CLI (proxy + memory) · CLI de headroom (proxy + memoria)"
      )
      printf '\n  %sShell commands · Comandos de shell%s\n' "$D" "$R"
      local c
      for c in "${cmds[@]}"; do printf '  %s%-18s%s %s\n' "$O" "${c%%:*}" "$R" "${c#*:}"; done
      local -a inclaude=(
        "/carryover:this command reference · esta referencia de comandos"
        "/recall <q>:recall knowledge by keyword · recordar conocimiento por keyword"
        "/wiki-enable:enable the auto-wiki here · activar la auto-wiki aquí"
        "/headroom:headroom status + memory · estado y memoria de headroom"
      )
      printf '\n  %s💬 In Claude — type in the chat, NOT this terminal · escríbelos en el chat%s\n' "$Y" "$R"
      for c in "${inclaude[@]}"; do printf '  %s%-18s%s %s\n' "$O" "${c%%:*}" "$R" "${c#*:}"; done
      if [ -d "$HOME/.claude/plugins/cache/ponytail" ]; then
        local -a pony=(
          "/ponytail:lite|full|ultra — lazy mode + intensity · modo lazy + intensidad"
          "/ponytail-review:review the diff for over-engineering · revisar el diff"
          "/ponytail-audit:audit the whole repo for bloat · auditar todo el repo"
          "/ponytail-debt:list deferred shortcuts · listar atajos diferidos"
          "/ponytail-help:ponytail quick reference · referencia rápida"
          "stop ponytail:back to normal mode · volver al modo normal"
        )
        printf '\n  %s💬 Ponytail — also in the chat, NOT this terminal · también en el chat%s\n' "$Y" "$R"
        for c in "${pony[@]}"; do printf '  %s%-18s%s %s\n' "$O" "${c%%:*}" "$R" "${c#*:}"; done
      fi;;
    doctor) bash "$HOME/.claude/hooks/carryover-doctor.sh" "$2";;
    persist)   # make the headroom proxy survive reboot (bootstrap its launchd service from this real Terminal)
      local plist; plist=$(ls "$HOME"/Library/LaunchAgents/*headroom*.plist 2>/dev/null | head -1)
      [ -n "$plist" ] || { echo "$tag ${E}✗${R} no headroom launchd plist — run install.sh in a real Terminal first"; return 1; }
      local label; label=$(basename "$plist" .plist)
      launchctl bootstrap "gui/$(id -u)" "$plist" 2>/dev/null
      if launchctl kickstart -k "gui/$(id -u)/$label" 2>/dev/null; then
        echo "$tag ${G}✓${R} $label bootstrapped — survives reboot"
      else
        echo "$tag ${E}✗${R} bootstrap failed — run from a real Terminal (GUI session), not SSH/agent"; return 1
      fi;;
    version|--version|-v)
      local SRC="${CARRYOVER_SRC:-$HOME/carryover}"
      local v; v=$(python3 -c "import json,sys;print(json.load(open(sys.argv[1]))['version'])" "$SRC/.claude-plugin/plugin.json" 2>/dev/null || echo '?')
      echo "$tag ${O}$v${R} ${D}($(git -C "$SRC" rev-parse --short HEAD 2>/dev/null || echo '?'))${R}"
      if git -C "$SRC" fetch -q origin master 2>/dev/null; then
        local n; n=$(git -C "$SRC" rev-list --count HEAD..origin/master 2>/dev/null || echo 0)
        [ "${n:-0}" -gt 0 ] && echo "  ${Y}$n update(s) available${R} → run: carryover update" || echo "  ${G}up to date ✓${R}"
      fi;;
    update)
      local SRC="${CARRYOVER_SRC:-$HOME/carryover}"
      [ -d "$SRC/.git" ] || { echo "$tag ${E}✗${R} no checkout at $SRC (set CARRYOVER_SRC)"; return 1; }
      git -C "$SRC" -c http.lowSpeedLimit=1000 -c http.lowSpeedTime=20 pull --ff-only || { echo "$tag ${E}✗${R} 'git pull' failed/timed out in $SRC (network down, or repo dirty/diverged?)"; return 1; }
      bash "$SRC/install.sh" --files-only || return 1
      if pgrep -f "carryover/carryover-dash.py" >/dev/null; then
        pkill -f "carryover/carryover-dash.py"
        (nohup python3 "$HOME/.carryover/carryover-dash.py" >>"$HOME/.carryover/dash.log" 2>&1 &)
        echo "$tag ${D}dashboard restarted${R}"
      fi
      echo "$tag ${G}✓ done${R}${D} (source: $SRC)${R}"
      if [ -r "$HOME/.carryover/carryover.zsh" ]; then
        source "$HOME/.carryover/carryover.zsh" 2>/dev/null   # don't gate on exit code: it reflects the snippet's last line, not failure
        echo "$tag ${G}✓ reloaded${R}${D} — new commands are live in this shell${R}"
      else
        echo "  ${D}reload to pick up command changes:${R} source ~/.zshrc"
      fi;;
    wrap) shift
      local _t="${1:-}"
      case "$_t" in
        --clear|clear) rm -f "$HOME/.carryover/wrapped"; echo "$tag ${D}wrap list cleared${R}"; return 0;;
        windsurf|devin) echo "Point Windsurf at the proxy: set its OpenAI base URL to http://127.0.0.1:${HEADROOM_PORT:-8787}/v1";;
        "") echo "usage: carryover wrap <cursor|codex|aider|copilot|windsurf|…>  ·  carryover wrap --clear"; return 0;;
        *) if [ -x "$HOME/.headroom/venv/bin/headroom" ]; then "$HOME/.headroom/venv/bin/headroom" wrap "$@"; else echo "$tag ${Y}✗${R}${D} wrap needs the headroom proxy (not installed)${R}"; return 1; fi;;
      esac
      # remember wrapped non-Claude tools so 'carryover off' can warn they still route
      [ -n "$_t" ] && { mkdir -p "$HOME/.carryover"; grep -qxF "$_t" "$HOME/.carryover/wrapped" 2>/dev/null || echo "$_t" >> "$HOME/.carryover/wrapped"; };;
    uninstall) bash "${CARRYOVER_SRC:-$HOME/carryover}/uninstall.sh";;
    *) echo "$tag ${D}usage:${R} on|off [--session]|status|doctor [--fix]|persist|update|version|wrap <tool>|uninstall";;
  esac
}
# apply global bypass in new shells (set by 'carryover off')
[ -f "$HOME/.carryover/.bypass" ] && unset ANTHROPIC_BASE_URL OPENAI_BASE_URL
# <<< headroom aliases <<<
