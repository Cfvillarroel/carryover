
# >>> headroom aliases >>>
export HEADROOM_DB="$HOME/.headroom/memory.db"   # store real del proxy (no el ./headroom_memory.db del cwd)
alias hr="$HOME/.headroom/venv/bin/headroom"     # CLI base
alias hr-status="hr install status"              # ¿proxy arriba/sano?
alias hr-mem="hr memory list --db-path \"$HEADROOM_DB\""    # memorias guardadas
alias hr-stats="hr memory stats --db-path \"$HEADROOM_DB\"" # resumen de memoria
alias hr-save="hr output-savings"               # tokens ahorrados
alias mem-save="bash $HOME/.claude/hooks/mem-save.sh"  # guardar una memoria a mano
alias hr-on="hr install start"                  # arrancar proxy
alias hr-off="hr install stop"                  # parar proxy
# <<< headroom aliases <<<
