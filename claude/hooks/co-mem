#!/usr/bin/env python3
"""carryover memory CLI — thin resolver over co_store for shell consumers (recall, forget,
doctor) and the dashboard. Routes to headroom or the built-in SQLite store transparently.
Usage: co-mem export <file> | import <file> | delete <id…> | edit <id> [--content X] [--importance Y]
       | touch <id…> | supersede <old> <new> | recall [--repo R] [--all] <query…> | search <query…>
       | stats | backend"""
import json
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))
import co_store  # noqa: E402

a = sys.argv[1:]
cmd = a[0] if a else ""

if cmd == "export" and len(a) > 1:
    json.dump(co_store.export(), open(a[1], "w"), ensure_ascii=False)
elif cmd == "delete":
    print(co_store.delete(a[1:]))
elif cmd == "edit" and len(a) > 1:
    content = importance = None
    rest, i = a[2:], 0
    while i < len(rest):
        if rest[i] == "--content" and i + 1 < len(rest):
            content = rest[i + 1]; i += 2
        elif rest[i] == "--importance" and i + 1 < len(rest):
            importance = rest[i + 1]; i += 2
        else:
            i += 1
    print("ok" if co_store.edit(a[1], content, importance) else "fail")
elif cmd == "touch":
    print(co_store.touch(a[1:]))
elif cmd == "import":
    print(co_store.import_(a[1]))
elif cmd == "supersede":
    print(co_store.supersede(a[1], a[2]))
elif cmd == "search":
    print(json.dumps(co_store.search(" ".join(a[1:])) or [], ensure_ascii=False))
elif cmd == "recall":
    args, repo, allrepos, words, i = a[1:], None, False, [], 0
    while i < len(args):
        if args[i] == "--repo":
            repo = args[i + 1]; i += 2
        elif args[i] in ("--all", "-a"):
            allrepos = True; i += 1
        else:
            words.append(args[i]); i += 1
    repos = None if allrepos else (co_store.group_for(repo) if repo else None)
    print(json.dumps(co_store.recall(query=" ".join(words) or None, repos=repos), ensure_ascii=False))
elif cmd == "stats":
    print(co_store.stats())
elif cmd == "backend":
    b, db = co_store.backend()
    print(f"{b}\t{db}")
elif cmd == "send" and len(a) > 2:                    # co-mem send <to> <message...>
    import asyncio
    print(asyncio.run(co_store.send_msg(a[1], " ".join(a[2:]))))
elif cmd == "inbox":                                  # co-mem inbox [who] [--peek]
    peek = "--peek" in a[1:]
    who = next((x for x in a[1:] if not x.startswith("-")), None)
    print(json.dumps(co_store.inbox(who=who, consume=not peek), ensure_ascii=False))
elif cmd == "connect" and len(a) > 1:                 # co-mem connect <ws>
    print(json.dumps(sorted(co_store.connect(a[1])), ensure_ascii=False))
elif cmd == "disconnect" and len(a) > 1:              # co-mem disconnect <ws>
    print(json.dumps(sorted(co_store.disconnect(a[1])), ensure_ascii=False))
elif cmd == "connections":                            # co-mem connections
    print(json.dumps(sorted(co_store.peers()), ensure_ascii=False))
elif cmd == "say" and len(a) > 1:                     # co-mem say <message...>
    import asyncio
    prs = sorted(co_store.peers())
    if not prs:
        sys.stderr.write("co-say: not connected to any workspace — first run: co-connect <workspace>\n")
        sys.exit(1)
    msg = " ".join(a[1:])
    ids = [asyncio.run(co_store.send_msg(p, msg)) for p in prs]
    print(json.dumps({"to": prs, "ids": ids}, ensure_ascii=False))
else:
    sys.stderr.write("usage: co-mem export <file> | delete <id…> | edit <id> [--content X] [--importance Y] "
                     "| touch <id…> | send <to> <msg> | inbox [who] [--peek] "
                     "| connect <ws> | disconnect <ws> | connections | say <msg> | stats | backend\n")
    sys.exit(1)
