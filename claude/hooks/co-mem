#!/usr/bin/env python3
"""carryover memory CLI — thin resolver over co_store for shell consumers (recall, forget,
doctor) and the dashboard. Routes to headroom or the built-in SQLite store transparently.
Usage: co-mem export <file> | import <file> | delete <id…> | edit <id> [--content X] [--importance Y]
       | touch <id…> | supersede <old> <new> | recall [--repo R] [--all] <query…> | search <query…>
       | vault [dir] [--repo R] | vault-import [dir] [--apply] | stats | backend"""
import json
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))
import co_store  # noqa: E402

a = sys.argv[1:]
cmd = a[0] if a else ""

if cmd == "export" and len(a) > 1:
    json.dump(co_store.export(), open(a[1], "w"), ensure_ascii=False)
elif cmd == "delete":
    print(co_store.delete(a[1:]))
elif cmd == "edit" and len(a) > 1:
    content = importance = None
    rest, i = a[2:], 0
    while i < len(rest):
        if rest[i] == "--content" and i + 1 < len(rest):
            content = rest[i + 1]; i += 2
        elif rest[i] == "--importance" and i + 1 < len(rest):
            importance = rest[i + 1]; i += 2
        else:
            i += 1
    print("ok" if co_store.edit(a[1], content, importance) else "fail")
elif cmd == "touch":
    print(co_store.touch(a[1:]))
elif cmd == "import":
    print(co_store.import_(a[1]))
elif cmd == "vault":                                  # co-mem vault [dir] [--repo R]  → Obsidian vault
    out, repo, i = os.path.expanduser("~/Documents/carryover-vault"), None, 1
    while i < len(a):
        if a[i] == "--repo" and i + 1 < len(a):
            repo = a[i + 1]; i += 2
        elif not a[i].startswith("-"):
            out = a[i]; i += 1
        else:
            i += 1
    print(json.dumps(co_store.export_vault(out, repos=co_store.group_for(repo) if repo else None), ensure_ascii=False))
elif cmd == "vault-import":                            # co-mem vault-import [dir] [--apply]  ← edits back
    out = next((x for x in a[1:] if not x.startswith("-")), os.path.expanduser("~/Documents/carryover-vault"))
    print(json.dumps(co_store.import_vault(out, apply="--apply" in a), ensure_ascii=False))
elif cmd == "vault-describe":                          # co-mem vault-describe [dir]  → LLM entity blurbs
    out = next((x for x in a[1:] if not x.startswith("-")), os.path.expanduser("~/Documents/carryover-vault"))
    print(json.dumps(co_store.describe_entities(out), ensure_ascii=False))
elif cmd == "vault-merge":                             # co-mem vault-merge  → LLM semantic entity merge map
    print(json.dumps(co_store.merge_entities(), ensure_ascii=False))
elif cmd == "supersede":
    print(co_store.supersede(a[1], a[2]))
elif cmd == "search":
    print(json.dumps(co_store.search(" ".join(a[1:])) or [], ensure_ascii=False))
elif cmd == "recall":
    args, repo, allrepos, words, i = a[1:], None, False, [], 0
    while i < len(args):
        if args[i] == "--repo":
            repo = args[i + 1]; i += 2
        elif args[i] in ("--all", "-a"):
            allrepos = True; i += 1
        else:
            words.append(args[i]); i += 1
    repos = None if allrepos else (co_store.group_for(repo) if repo else None)
    print(json.dumps(co_store.recall(query=" ".join(words) or None, repos=repos), ensure_ascii=False))
elif cmd == "stats":
    print(co_store.stats())
elif cmd == "backend":
    b, db = co_store.backend()
    print(f"{b}\t{db}")
elif cmd == "send" and len(a) > 2:                    # co-mem send <to> <message...>
    import asyncio
    print(asyncio.run(co_store.send_msg(a[1], " ".join(a[2:]))))
elif cmd == "handover" and len(a) > 2:                # co-mem handover <to> <message...>
    import asyncio
    mid = asyncio.run(co_store.send_msg(a[1], " ".join(a[2:]), handover=True))
    co_store.notify(a[1], " ".join(a[2:]))
    print(mid)
elif cmd == "inbox":                                  # co-mem inbox [who] [--peek] [--all]
    peek = "--peek" in a[1:]
    hist = "--all" in a[1:]                            # re-read incl. already-delivered; read-only
    who = next((x for x in a[1:] if not x.startswith("-")), None)
    print(json.dumps(co_store.inbox(who=who, consume=not peek and not hist, history=hist), ensure_ascii=False))
elif cmd == "connect" and len(a) > 1:                 # co-mem connect <ws>
    print(json.dumps(sorted(co_store.connect(a[1])), ensure_ascii=False))
elif cmd == "disconnect" and len(a) > 1:              # co-mem disconnect <ws>
    print(json.dumps(sorted(co_store.disconnect(a[1])), ensure_ascii=False))
elif cmd == "connections":                            # co-mem connections
    print(json.dumps(sorted(co_store.peers()), ensure_ascii=False))
elif cmd == "say" and len(a) > 1:                     # co-mem say <message...>
    import asyncio
    prs = sorted(co_store.peers())
    if not prs:
        sys.stderr.write("co-say: not connected to any workspace — first run: co-connect <workspace>\n")
        sys.exit(1)
    msg = " ".join(a[1:])
    ids = [asyncio.run(co_store.send_msg(p, msg)) for p in prs]
    print(json.dumps({"to": prs, "ids": ids}, ensure_ascii=False))
elif cmd == "team":                                   # co-mem team [list] | add|rm | send|assign
    sub = a[1] if len(a) > 1 else "list"
    if sub in ("list", "ls") or len(a) == 1:
        print(json.dumps(co_store.teams(), ensure_ascii=False))
    elif sub == "add" and len(a) > 3:                 # team add <team> <ws> [role]
        role = a[4] if len(a) > 4 else "member"
        print(json.dumps(co_store.team_add(a[2], a[3], role), ensure_ascii=False))
    elif sub in ("rm", "remove") and len(a) > 2:      # team rm <team> [ws]
        print(json.dumps(co_store.team_remove(a[2], a[3] if len(a) > 3 else None), ensure_ascii=False))
    elif sub in ("send", "assign") and len(a) > 3:    # team send|assign <team> [@role] <msg...>
        import asyncio
        rest = a[3:]
        role = None
        if rest[0].startswith("@") and len(rest[0]) > 1 and len(rest) > 1 \
                and co_store.team_members(a[2], rest[0][1:]):   # only consume @role if it matches real members
            role, rest = rest[0][1:], rest[1:]
        msg, members, ho = " ".join(rest), co_store.team_members(a[2], role), sub == "assign"
        if not msg or not members:
            sys.stderr.write(f"co-team {sub}: no message or no matching members in '{a[2]}'\n")
            sys.exit(1)
        ids = []
        for m in members:
            ids.append(asyncio.run(co_store.send_msg(m, msg, handover=ho)))
            if ho:
                co_store.notify(m, msg)
        print(json.dumps({"team": a[2], "to": members, "ids": ids, "handover": ho}, ensure_ascii=False))
    else:
        sys.stderr.write("usage: co-mem team [list] | add <team> <ws> [role] | rm <team> [ws] | send|assign <team> [@role] <msg>\n")
        sys.exit(1)
else:
    sys.stderr.write("usage: co-mem export <file> | delete <id…> | edit <id> [--content X] [--importance Y] "
                     "| touch <id…> | vault [dir] [--repo R] | vault-import [dir] [--apply] "
                     "| send <to> <msg> | inbox [who] [--peek] [--all] "
                     "| connect <ws> | disconnect <ws> | connections | say <msg> "
                     "| team [list|add|rm|send|assign] | stats | backend\n")
    sys.exit(1)
